[Unit]
Description=LobeChat AI Platform
After=network.target network-online.target docker.service
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
User=azureuser
WorkingDirectory=/home/azureuser
ExecStartPre=-/usr/bin/docker rm -f lobe-chat
ExecStartPre=/usr/bin/docker compose -f /home/azureuser/docker-compose.lobechat.yml pull
ExecStart=/usr/bin/docker compose -f /home/azureuser/docker-compose.lobechat.yml up -d --remove-orphans
ExecStop=/usr/bin/docker compose -f /home/azureuser/docker-compose.lobechat.yml down

[Install]
WantedBy=multi-user.target
